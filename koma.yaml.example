defaults:
  text: gemini-2.5-pro
  image: gemini-2.5-flash-image
  video: seedance-1.5-pro
  tts: doubao-tts

providers:
  vertex-ai:
    type: vertex-ai
    project: your-gcp-project-id
    location: us-central1
    service_account:
      client_email: your-service-account@your-gcp-project-id.iam.gserviceaccount.com
      private_key: "-----BEGIN PRIVATE KEY-----\n<your-private-key>\n-----END PRIVATE KEY-----\n"
    models:
      - gemini-2.5-pro
      - gemini-2.5-flash
      - gemini-2.5-flash-image

  volcengine-ark:
    type: volcengine-ark
    key: your-ark-api-key
    models:
      - seedance-2.0
      - seedance-1.5-pro

  volcengine-tts:
    type: volcengine-tts
    appid: "your-volcengine-tts-appid"
    key: your-access-token
    cluster: volcano_tts
    models:
      - doubao-tts

  # openai:
